{
	"name": "@mikolajbadyl/hawcode",
	"version": "0.3.0",
	"private": true,
	"type": "module",
	"hawcodeConfig": {
		"name": "hawcode",
		"configDir": ".hawcode"
	},
	"scripts": {
		"clean": "shx rm -rf dist",
		"build": "bun run clean && bun build --compile src/bun/cli.ts --outfile dist/hawcode && bun run copy-assets",
		"copy-assets": "shx mkdir -p dist/assets dist/export-html/vendor && shx cp src/modes/interactive/assets/*.png dist/assets/ && shx cp src/core/export-html/template.html dist/export-html/ && shx cp src/core/export-html/template.css dist/export-html/ && shx cp src/core/export-html/template.js dist/export-html/ && shx cp src/core/export-html/vendor/*.js dist/export-html/vendor/ && shx cp node_modules/@silvia-odwyer/photon-node/photon_rs_bg.wasm dist/ && shx cp package.json dist/package.json",
		"dev": "bun src/bun/cli.ts",
		"check": "biome check --write --error-on-warnings . && tsc --noEmit",
		"test": "echo 'no tests'"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.73.0",
		"@ast-grep/napi": "^0.42.1",
		"@google/genai": "^1.40.0",
		"@mariozechner/jiti": "^2.6.5",
		"@mistralai/mistralai": "1.14.1",
		"@opentui/core": "^0.1.99",
		"@opentui/react": "^0.1.99",
		"@silvia-odwyer/photon-node": "^0.3.4",
		"@sinclair/typebox": "^0.34.41",
		"@tavily/core": "^0.7.2",
		"@upstash/context7-sdk": "^0.3.0",
		"ajv": "^8.17.1",
		"ajv-formats": "^3.0.1",
		"chalk": "^5.5.0",
		"cli-highlight": "^2.1.11",
		"diff": "^8.0.2",
		"extract-zip": "^2.0.1",
		"fast-glob": "^3.3.3",
		"file-type": "^21.1.1",
		"glob": "^13.0.1",
		"hosted-git-info": "^9.0.2",
		"ignore": "^7.0.5",
		"marked": "^15.0.12",
		"marked-terminal": "^7.3.0",
		"minimatch": "^10.2.3",
		"openai": "6.26.0",
		"partial-json": "^0.1.7",
		"proper-lockfile": "^4.1.2",
		"proxy-agent": "^6.5.0",
		"react": "^19.2.5",
		"react-devtools-core": "^7.0.1",
		"strip-ansi": "^7.1.0",
		"undici": "^7.19.1",
		"uuid": "^11.1.0",
		"vscode-jsonrpc": "^8.2.1",
		"vscode-languageserver-types": "^3.17.5",
		"yaml": "^2.8.2",
		"zod-to-json-schema": "^3.24.6"
	},
	"optionalDependencies": {
		"@mariozechner/clipboard": "^0.3.2"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.5",
		"@types/diff": "^7.0.2",
		"@types/hosted-git-info": "^3.0.5",
		"@types/ms": "^2.1.0",
		"@types/node": "^24.3.0",
		"@types/proper-lockfile": "^4.1.4",
		"@types/react": "^19.2.14",
		"shx": "^0.4.0",
		"typescript": "^6.0.3",
		"typescript-language-server": "^5.1.3"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"overrides": {
		"rimraf": "6.1.2",
		"gaxios": {
			"rimraf": "6.1.2"
		}
	}
}
